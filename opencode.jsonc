{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",

    "bash": {
      "*": "ask",

      // DOTNET ALLOW
      "dotnet build *": "allow",
      "dotnet test *": "allow",

      // GIT ALLOW
      "git branch": "allow",
      "git branch --show-current": "allow",
      "git diff *": "allow",
      "git fetch": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git status": "allow",

      // GIT ASK
      "git add *": "ask",
      "git commit *": "ask",
      "git checkout *": "ask",
      "git pull": "ask",
      "git pull *": "ask",

      // GIT DENY
      "git cherry-pick *": "deny",
      "git clean *": "deny",
      "git config *": "deny",
      "git merge *": "deny",
      "git push *": "deny",
      "git rebase *": "deny",
      "git reset *": "deny",
      "git restore *": "deny",
      "git stash *": "deny",

      // NEOVIM ALLOW
      "nvim --version": "allow",

      // UNIX ALLOW
      "ls": "allow"
    },

    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "read": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow"
  }
}
